#!/bin/bash

PROJECT_ROOT="$(cd "$(dirname "$0")" && pwd)"

# Check if askpass script exists to run sudo without prompting
ASKPASS_PATH="/dev/shm/exchange_askpass_${USER}.sh"
SUDO_CMD="sudo"
if [ -f "$ASKPASS_PATH" ]; then
    SUDO_CMD="SUDO_ASKPASS='$ASKPASS_PATH' sudo -A"
fi

echo "=== Stopping Exchange Client Agents ==="
pkill -f "build/client-agents/"
tmux kill-session -t "exchange_agents" 2>/dev/null || true

echo "=== Stopping Exchange Core Services ==="
$SUDO_CMD pkill -f "build/services/"
tmux kill-session -t "exchange" 2>/dev/null || true

echo "=== Cleaning up shared memory files ==="
$SUDO_CMD rm -f /dev/shm/ORDER_REQUEST \
        /dev/shm/ORDER_RESPONSE \
        /dev/shm/MARKET_DATA_RING \
        /dev/shm/EXCHANGE_TELEMETRY \
        /dev/shm/*TELEMETRY 2>/dev/null || true

# Clean up askpass file
rm -f "$ASKPASS_PATH"

echo "=== All processes stopped ==="
