#!/bin/bash

# Enforce running with sudo/root privileges upfront
if [ "$EUID" -ne 0 ]; then
    echo "Error: This script must be run as root/sudo." >&2
    exit 1
fi

PROJECT_ROOT="$(cd "$(dirname "$0")" && pwd)"
BUILD_AGENT_DIR="$PROJECT_ROOT/build/client-agents"
LOG_DIR="$PROJECT_ROOT/log"
SESSION="exchange_agents"

mkdir -p "$LOG_DIR"

# We don't need sudo askpass since EUID=0 is enforced.

echo ""
echo "=== Starting Exchange Core Services ==="
"$PROJECT_ROOT/run-services"

echo "Waiting 1 second for services to initialize..."
sleep 1

# Grant read/write permissions on the created shared memory segments to allow client agents to connect
chmod 666 /dev/shm/ORDER_REQUEST* \
               /dev/shm/ORDER_RESPONSE \
               /dev/shm/MARKET_DATA_RING \
               /dev/shm/EXCHANGE_TELEMETRY \
               /dev/shm/*TELEMETRY 2>/dev/null || true

echo ""
echo "=== Starting Exchange Client Agents (MM and Noise) ==="

# Check CPU count and set the appropriate Tier
NUM_CORES=$(nproc)
if [ "$NUM_CORES" -lt 3 ]; then
    TIER=1
elif [ "$NUM_CORES" -eq 3 ]; then
    TIER=2
elif [ "$NUM_CORES" -eq 4 ]; then
    TIER=3
else
    TIER=4
fi

# Find and filter executable agents dynamically
ALL_AGENTS=($(find "$BUILD_AGENT_DIR" -maxdepth 1 -type f -executable | sort))
AGENTS=()
for agent in "${ALL_AGENTS[@]}"; do
    name=$(basename "$agent")
    if [[ "$name" == *mm* || "$name" == *noise* ]]; then
        AGENTS+=("$agent")
    fi
done

if [ ${#AGENTS[@]} -eq 0 ]; then
    echo "Error: No MM or Noise executable agents found in $BUILD_AGENT_DIR."
    exit 1
fi

get_run_cmd() {
    local exe_path="$1"
    local agent_name="$2"
    if [ "$TIER" -eq 1 ]; then
        echo "$exe_path"
    else
        local core_id=""
        if [ "$TIER" -eq 2 ]; then
            core_id="0"
        elif [ "$TIER" -eq 3 ]; then
            core_id="3"
        elif [ "$TIER" -ge 4 ]; then
            core_id="4"
        fi
        
        if [ -n "$core_id" ]; then
            echo "taskset -c $core_id $exe_path"
        else
            echo "$exe_path"
        fi
    fi
}

# Start a new detached session with the first agent
first_exe="${AGENTS[0]}"
first_name=$(basename "$first_exe")
log="$LOG_DIR/${first_name}.log"
first_run_cmd=$(get_run_cmd "$first_exe" "$first_name")

tmux new-session -d -s "$SESSION" -n "$first_name" "bash -c 'while true; do echo \"--- Starting $first_name ---\"; $first_run_cmd 2>&1 | tee -a $log; echo \"--- $first_name stopped/crashed, restarting in 2s ---\"; sleep 2; done'"

# Configure status bar for help
tmux set-option -t "$SESSION" status-bg black
tmux set-option -t "$SESSION" status-fg white

# Bind Ctrl+B + Arrows to switch windows easily
tmux bind-key -r Left select-window -t :-
tmux bind-key -r Right select-window -t :+

# Create windows for the remaining agents
for ((i=1; i<${#AGENTS[@]}; i++)); do
    exe="${AGENTS[$i]}"
    name=$(basename "$exe")
    log="$LOG_DIR/${name}.log"
    run_cmd=$(get_run_cmd "$exe" "$name")
    
    # Run the agent in a loop for auto-restart
    tmux new-window -t "$SESSION" -n "$name" "bash -c 'while true; do echo \"--- Starting $name ---\"; $run_cmd 2>&1 | tee -a $log; echo \"--- $name stopped/crashed, restarting in 2s ---\"; sleep 2; done'"
done

# Select the first window by default
tmux select-window -t "$SESSION":0

echo "Agents successfully started. To view them, run: sudo tmux attach -t $SESSION"
