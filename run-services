#!/bin/bash

PROJECT_ROOT="$(cd "$(dirname "$0")" && pwd)"
BUILD_SERVICE_DIR="$PROJECT_ROOT/build/services"
LOG_DIR="$PROJECT_ROOT/log"
SESSION="exchange"

mkdir -p "$LOG_DIR"

# Check if any service is running (either tmux session exists or processes are active)
if tmux list-sessions -F '#S' 2>/dev/null | grep -q -x "$SESSION" || pgrep -f "build/services/" >/dev/null; then
    echo "One or more core services are already running. Stopping services and cleaning up shared memory..."
    "$PROJECT_ROOT/kill-all"
fi

# Check CPU count and set the appropriate Tier
NUM_CORES=$(nproc)
if [ "$NUM_CORES" -lt 8 ]; then
    TIER=1
    TIER_NAME="Low Power (Cores: $NUM_CORES)"
elif [ "$NUM_CORES" -lt 24 ]; then
    TIER=2
    TIER_NAME="Dedicated Cores (Cores: $NUM_CORES)"
else
    TIER=3
    TIER_NAME="Full Isolation (Cores: $NUM_CORES)"
fi

echo "Detected CPU cores: $NUM_CORES. Applying Tier $TIER: $TIER_NAME configuration."

ASKPASS_PATH="/dev/shm/exchange_askpass_${USER}.sh"
SUDO_CMD="sudo"

# Setup askpass if sudo is needed (Tier 2 or 3)
if [ "$TIER" -gt 1 ]; then
    # Helper to check if sudo requires password inside tmux
    needs_sudo_auth() {
        if [ "$EUID" -eq 0 ]; then
            return 1
        fi
        # If we already have a valid askpass set up, we don't need to prompt again
        if [ -n "$SUDO_ASKPASS" ] && [ -x "$SUDO_ASKPASS" ] && SUDO_ASKPASS="$SUDO_ASKPASS" sudo -A true 2>/dev/null; then
            return 1
        fi
        if [ -x "$ASKPASS_PATH" ] && SUDO_ASKPASS="$ASKPASS_PATH" sudo -A true 2>/dev/null; then
            export SUDO_ASKPASS="$ASKPASS_PATH"
            return 1
        fi
        # Check if passwordless sudo is already available in a new tmux session
        rm -f /dev/shm/sudo_ok
        tmux new-session -d -s check_sudo_session 'sudo -n true 2>/dev/null && touch /dev/shm/sudo_ok' 2>/dev/null
        sleep 0.2
        tmux kill-session -t check_sudo_session 2>/dev/null
        if [ -f /dev/shm/sudo_ok ]; then
            rm -f /dev/shm/sudo_ok
            return 1
        fi
        return 0
    }

    if needs_sudo_auth; then
        echo "This script requires sudo privileges to set real-time priority or modify CPU nice values."
        echo -n "[sudo] password for $USER: "
        read -s SUDO_PASS
        echo ""
        if ! echo "$SUDO_PASS" | sudo -S true 2>/dev/null; then
            echo "Error: Invalid sudo password."
            exit 1
        fi
        cat <<EOF > "$ASKPASS_PATH"
#!/bin/bash
echo "$SUDO_PASS"
EOF
        chmod 700 "$ASKPASS_PATH"
        export SUDO_ASKPASS="$ASKPASS_PATH"
    fi

    if [ -n "$SUDO_ASKPASS" ]; then
        SUDO_CMD="sudo -A"
    fi
fi

# Find all executable services dynamically, verifying they correspond to source files
SERVICES=()
for src in "$PROJECT_ROOT/app/services"/*.cpp; do
    [ -e "$src" ] || continue
    base=$(basename "$src" .cpp)
    exe="$BUILD_SERVICE_DIR/$base"
    if [ -x "$exe" ]; then
        SERVICES+=("$exe")
    fi
done

# Sort the services array
if [ ${#SERVICES[@]} -gt 0 ]; then
    IFS=$'\n' SERVICES=($(printf '%s\n' "${SERVICES[@]}" | sort))
    unset IFS
fi

if [ ${#SERVICES[@]} -eq 0 ]; then
    echo "Error: No executable services found in $BUILD_SERVICE_DIR. Please compile the project first using 'make'."
    exit 1
fi

get_run_cmd() {
    local exe_path="$1"
    local service_name="$2"
    if [ "$TIER" -eq 1 ]; then
        echo "$exe_path"
    elif [ "$TIER" -eq 2 ]; then
        # Tier 2: Dedicated Cores. Set MAIN_CORE env var, use nice -n -20 (no RT)
        case "$service_name" in
            "matching-engine")    main_core="1" ;;
            "client-manager")     main_core="2" ;;
            "market-data-server") main_core="3" ;;
            "http-accepter")      main_core="5" ;;
            "public-data")        main_core="6" ;;
        esac
        if [ -n "$main_core" ]; then
            echo "$SUDO_CMD MAIN_CORE=$main_core nice -n -20 $exe_path"
        else
            echo "$exe_path"
        fi
    else
        # Tier 3: Full Isolation. Set MAIN_CORE and BG_CORE env vars, use chrt -f 99 (RT)
        local main_core=""
        local bg_core=""
        case "$service_name" in
            "matching-engine")    main_core="1" ;;
            "client-manager")     main_core="2"; bg_core="18" ;;
            "market-data-server") main_core="3"; bg_core="19" ;;
            "http-accepter")      main_core="5"; bg_core="21" ;;
            "public-data")        main_core="6"; bg_core="22" ;;
        esac
        
        local env_vars=""
        if [ -n "$main_core" ]; then
            env_vars="MAIN_CORE=$main_core"
            if [ -n "$bg_core" ]; then
                env_vars="$env_vars BG_CORE=$bg_core"
            fi
        fi
        
        if [ -n "$env_vars" ]; then
            echo "$SUDO_CMD $env_vars chrt -f 99 $exe_path"
        else
            echo "$exe_path"
        fi
    fi
}

echo "Starting $SESSION services in the background (detached tmux session)..."

# Start a new detached session with the first service
first_exe="${SERVICES[0]}"
first_name=$(basename "$first_exe")
log="$LOG_DIR/${first_name}.log"
first_run_cmd=$(get_run_cmd "$first_exe" "$first_name")

tmux new-session -d -s "$SESSION" -n "$first_name" "SUDO_ASKPASS='$SUDO_ASKPASS' bash -c 'while true; do echo \"--- Starting $first_name ---\"; $first_run_cmd 2>&1 | tee -a $log; echo \"--- $first_name crashed, restarting in 2s ---\"; sleep 2; done'"

# Configure status bar for help
tmux set-option -t "$SESSION" status-bg black
tmux set-option -t "$SESSION" status-fg white

# Bind Ctrl+B + Arrows to switch windows easily
tmux bind-key -r Left select-window -t :-
tmux bind-key -r Right select-window -t :+

# Create windows for the remaining services
for ((i=1; i<${#SERVICES[@]}; i++)); do
    exe="${SERVICES[$i]}"
    name=$(basename "$exe")
    log="$LOG_DIR/${name}.log"
    run_cmd=$(get_run_cmd "$exe" "$name")
    
    # Run the service in a loop for health check/auto-restart
    tmux new-window -t "$SESSION" -n "$name" "SUDO_ASKPASS='$SUDO_ASKPASS' bash -c 'while true; do echo \"--- Starting $name ---\"; $run_cmd 2>&1 | tee -a $log; echo \"--- $name crashed, restarting in 2s ---\"; sleep 2; done'"
done

# Select the first window by default
tmux select-window -t "$SESSION":0

echo "Services successfully started. To view them, run: tmux attach -t $SESSION"
