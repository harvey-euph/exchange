#!/bin/bash

# 1. Enforce running with sudo/root privileges upfront
if [ "$EUID" -ne 0 ]; then
    echo "Error: This script must be run as root/sudo." >&2
    exit 1
fi

set -e

# Ensure directory is project root
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
cd "$PROJECT_ROOT"

echo "=== Run Benchmark Script Started ==="

# Resolve the original non-root user
RUNNING_USER="${SUDO_USER:-$USER}"

# Source user's environment
export HOME="/home/harvey"
source /home/harvey/.bashrc || true
export PATH="/home/harvey/.local/bin:$PATH"

run_git() {
    sudo -u "$RUNNING_USER" git "$@"
}

run_make() {
    sudo -u "$RUNNING_USER" PATH="$PATH" make "$@"
}

# Compile if needed
if [[ "${SKIP_BUILD:-}" != "true" ]]; then
    echo "Building project..."
    run_make -j$(nproc)
else
    echo "Skipping project build (SKIP_BUILD=true)..."
fi

# Global variables
EBPF_PID=""

cleanup() {
    echo "=== Performing cleanup ==="

    if [ -n "$EBPF_PID" ]; then
        echo "Stopping ebpf-msg-flow (PID: $EBPF_PID)..."
        sudo kill -SIGINT "$EBPF_PID" 2>/dev/null || true
    fi
    sudo pkill -SIGINT -f "ebpf-msg-flow" 2>/dev/null || true

    if tmux list-sessions -F '#S' 2>/dev/null | grep -q -x "exchange" || pgrep -f "build/services/" >/dev/null; then
        echo "Stopping services..."
        sudo ./kill-all || true
    fi

    if [ -n "$LOG_FILE" ] && [ -f "$LOG_FILE" ]; then
        chown "$RUNNING_USER:$RUNNING_USER" "$LOG_FILE" 2>/dev/null || true
        chmod 666 "$LOG_FILE" 2>/dev/null || true
        echo "Fixed ownership of log file: $LOG_FILE"
    fi

    chown -R "$RUNNING_USER:$RUNNING_USER" log/ 2>/dev/null || true
    chmod -R u+rwX log/ 2>/dev/null || true
}
trap cleanup EXIT

# Start services
echo "Starting services..."
sudo ./run-services
echo "Waiting 1 second for services to stabilize..."
sleep 1

REQUESTS="${1:-100000}"

# === 關鍵修改：Log 檔案建立 ===
BRANCH=$(run_git symbolic-ref --short HEAD 2>/dev/null || run_git rev-parse --short HEAD)
BRANCH="${BRANCH//\//_}"
COMMIT=$(run_git rev-parse --short=6 HEAD)
DATE=$(date +%Y%m%d-%H%M%S)
LOG_FILE="${BENCHMARK_LOG:-log/benchmark-${BRANCH}-${DATE}-${COMMIT}.parquet}"

mkdir -p log
touch "$LOG_FILE"
chown "$RUNNING_USER:$RUNNING_USER" "$LOG_FILE"
chmod 666 "$LOG_FILE"

echo "Logging stdout to: $LOG_FILE"

# Start ebpf-msg-flow
echo "Starting ebpf-msg-flow..."
# Use --parquet for compact binary output when available (Python reads via pyarrow).
# Detect support at runtime by checking the binary's --help output.
EBPF_BIN="./app/perf/ebpf/ebpf-msg-flow"
if strings "$EBPF_BIN" 2>/dev/null | grep -q "USE_PARQUET\|parquet"; then
    echo "Parquet mode available → $LOG_FILE"
    sudo "$EBPF_BIN" --parquet "$LOG_FILE" &
    EBPF_PID=$!
else
    echo "[warn] Parquet support not compiled in, falling back to CSV"
    LOG_FILE="${LOG_FILE%.parquet}.log"
    sudo "$EBPF_BIN" --raw >> "$LOG_FILE" &
    EBPF_PID=$!
fi
echo "Waiting 3 seconds for ebpf-msg-flow to stabilize..."
sleep 3

# Run benchmark
echo "Running benchmark-trader with ${REQUESTS} requests..."
./build/client-perf/benchmark-trader --requests "$REQUESTS"

# Stop ebpf
echo "Stopping ebpf-msg-flow..."
sudo kill -SIGINT "$EBPF_PID" 2>/dev/null || true
sleep 1
sudo pkill -SIGINT -f "ebpf-msg-flow" 2>/dev/null || true
EBPF_PID=""

echo "Stopping services..."
sudo ./kill-all || true

echo "Finished benchmark."