#!/bin/bash

if [ "$#" -ne 1 ]; then
    echo "Usage: $0 <test_directory>"
    echo "Example: $0 tests/md_test_mod_remaining_correctness"
    exit 1
fi

TEST_DIR=$1
INPUT_CSV="${TEST_DIR}/input.csv"
EXPECTED_CSV="${TEST_DIR}/expected-result.csv"

# Verify files exist
if [ ! -f "$INPUT_CSV" ]; then
    echo "Error: $INPUT_CSV not found!"
    exit 1
fi

if [ ! -f "$EXPECTED_CSV" ]; then
    echo "Error: $EXPECTED_CSV not found!"
    exit 1
fi

PROJECT_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
BUILD_DIR="$PROJECT_ROOT/build"

echo "=== Running test: $TEST_DIR ==="

# 1. 清乾淨 log 資料夾與 shared memory
echo "Cleaning logs and stopping old services..."
"$PROJECT_ROOT/scripts/kill-all" >/dev/null 2>&1 || true
rm -f "$PROJECT_ROOT/log/execution-journals/"* 2>/dev/null
rm -f "$PROJECT_ROOT/log/"*.log 2>/dev/null

# 2. 開啟 ME 用 csv_inserter 把 input.csv 寫入後關閉 ME，只留下產生的 log
echo "Starting Matching Engine..."
"$BUILD_DIR/services/matching-engine" >/dev/null 2>&1 &
ME_PID=$!

# Wait for ME to initialize SHM
sleep 0.5

echo "Inserting CSV data..."
"$BUILD_DIR/components/csv_inserter" "$INPUT_CSV"

# 等待 ME 處理完所有寫入的 Request 並輸出到 Journal
sleep 1

echo "Stopping Matching Engine..."
kill -SIGINT $ME_PID
wait $ME_PID 2>/dev/null

# 3. 開啟 MD 會去讀 log/execution-journals 建立 book
echo "Starting Market Data Server..."
"$BUILD_DIR/services/market-data-server" > md_out.log 2>&1 &
MD_PID=$!

sleep 1 # 等待 MD Server 把 Journal 讀完並建好 Book

# 4. 用 GDB 注入 MD Server 匯出 L3Book 狀態
echo "Dumping server book via GDB..."
gdb -p $MD_PID -batch -ex "call g_md_server->gdb_dump_book(1, \"${TEST_DIR}/server-book.csv\")" -ex "detach" -ex "quit" > /dev/null 2>&1

# 5. 開啟 Client Book Dumper 收取 Snapshot
echo "Starting Client Book Dumper..."
"$BUILD_DIR/components/client-book-dumper" 1 "${TEST_DIR}/client-book.csv" > client.log 2>&1 &
CLIENT_PID=$!

sleep 0.5 # 等待 Client 收完 Snapshot

echo "Stopping Client Book Dumper..."
kill -SIGINT $CLIENT_PID
wait $CLIENT_PID 2>/dev/null

# Cleanup MD
echo "Stopping Market Data Server..."
kill -SIGINT $MD_PID
wait $MD_PID 2>/dev/null

echo "Comparing server book with expected result..."
diff -q "${TEST_DIR}/server-book.csv" "$EXPECTED_CSV"
SERVER_CHECK=$?

echo "Comparing client book with expected result..."
diff -q "${TEST_DIR}/client-book.csv" "$EXPECTED_CSV"
CLIENT_CHECK=$?

if [ $SERVER_CHECK -eq 0 ]; then
    echo "✅ SERVER TEST PASSED: $TEST_DIR"
else
    echo "❌ SERVER TEST FAILED: $TEST_DIR"
    echo "--- Server Book Diff ---"
    diff "${TEST_DIR}/server-book.csv" "$EXPECTED_CSV"
fi

if [ $CLIENT_CHECK -eq 0 ]; then
    echo "✅ CLIENT TEST PASSED: $TEST_DIR"
else
    echo "❌ CLIENT TEST FAILED: $TEST_DIR"
    echo "--- Client Book Diff ---"
    diff "${TEST_DIR}/client-book.csv" "$EXPECTED_CSV"
fi

rm -f "${TEST_DIR}/server-book.csv" "${TEST_DIR}/client-book.csv"

if [ $SERVER_CHECK -eq 0 ] && [ $CLIENT_CHECK -eq 0 ]; then
    exit 0
else
    exit 1
fi
