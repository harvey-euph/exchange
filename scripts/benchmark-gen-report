#!/usr/bin/env bash
set -euo pipefail
set -x

# Ensure NEW_BRANCH is provided
NEW_BRANCH="${1:-${NEW_BRANCH:-}}"
if [[ -z "$NEW_BRANCH" ]]; then
  echo "Error: NEW_BRANCH must be passed as the first argument or set as an environment variable." >&2
  exit 1
fi

# Find VM zone dynamically
ZONE=$(gcloud compute instances list \
  --filter="name=vm-benchmark" \
  --format="value(zone)" | head -n 1)

if [[ -z "$ZONE" ]]; then
  echo "Error: vm-benchmark instance not found!" >&2
  exit 1
fi

echo "Found vm-benchmark in zone: $ZONE"

# Change directory to the root of the exchange repo
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
cd "$PROJECT_ROOT"

# === 新增：確保本地 log 目錄權限正確 ===
echo "Ensuring local log directory permissions..."
mkdir -p log
chown -R "$USER:$USER" log 2>/dev/null || true
chmod -R u+rwX log 2>/dev/null || true

cleanup() {
  echo "Cleaning up: Stopping vm-benchmark..."
  gcloud compute instances stop vm-benchmark --zone="$ZONE" || true

  # 本地 log 權限修復
  echo "Fixing local log directory permissions..."
  chown -R "$USER:$USER" "$PROJECT_ROOT/log" 2>/dev/null || true
  chmod -R u+rwX "$PROJECT_ROOT/log" 2>/dev/null || true

  rm -f main_benchmark.log new_benchmark.log || true
}

trap cleanup EXIT

# Check if VM is already running
STATUS=$(gcloud compute instances describe \
  vm-benchmark \
  --zone="$ZONE" \
  --format="value(status)" | tr -d '\r\n')

echo "Current status of vm-benchmark: $STATUS"

if [[ "$STATUS" == "RUNNING" ]]; then
  echo "vm-benchmark is already running. Skipping startup and stabilization wait."
else
  echo "Starting vm-benchmark..."
  gcloud compute instances start vm-benchmark --zone="$ZONE"

  echo "Waiting 20 seconds for VM to stabilize..."
  sleep 20
fi

###########################################################
echo "Waiting for SSH on vm-benchmark to become ready..."
###########################################################

SSH_READY=0
for i in $(seq 1 12); do
  echo "Attempt $i: Checking SSH connection..."
  if gcloud compute ssh vm-benchmark \
      --zone="$ZONE" \
      --quiet \
      --ssh-flag="-o StrictHostKeyChecking=no" \
      --ssh-flag="-o UserKnownHostsFile=/dev/null" \
      --ssh-flag="-o ConnectTimeout=5" \
      --command "echo 'SSH is ready'" >/dev/null 2>&1; then
    echo "SSH is ready!"
    SSH_READY=1
    break
  fi
  echo "SSH not ready yet, waiting 5 seconds..."
  sleep 5
done

if [[ "$SSH_READY" -ne 1 ]]; then
  echo "Error: vm-benchmark SSH failed to become ready after 1 minute!" >&2
  exit 1
fi

echo "New branch is: $NEW_BRANCH"

###########################################################
echo "Initializing and compiling branches on vm-benchmark..."
###########################################################

# 1. Compile main branch
gcloud compute ssh vm-benchmark \
  --zone="$ZONE" \
  --quiet \
  --ssh-flag="-o StrictHostKeyChecking=no" \
  --ssh-flag="-o UserKnownHostsFile=/dev/null" \
  --command "
    set -e
    cd ~/exchange-main
    git fetch origin
    git checkout main
    git reset --hard origin/main
    git clean -fd

    make clean
    make -j\$(nproc) benchmark

    # Clean previous combined log (no sudo)
    rm -f log/benchmark-main-combined.log
    mkdir -p log
  "

# 2. Compile new branch
gcloud compute ssh vm-benchmark \
  --zone="$ZONE" \
  --quiet \
  --ssh-flag="-o StrictHostKeyChecking=no" \
  --ssh-flag="-o UserKnownHostsFile=/dev/null" \
  --command "
    set -e
    cd ~/exchange-new
    git fetch origin \"$NEW_BRANCH\"
    git checkout -B \"$NEW_BRANCH\" FETCH_HEAD
    git reset --hard FETCH_HEAD
    git clean -fd

    make clean
    make -j\$(nproc) benchmark

    # Clean previous combined log (no sudo)
    rm -f log/benchmark-new-combined.log
    mkdir -p log
  "

###########################################################
echo "Running alternating benchmarks (5 iterations x 100k requests)..."
###########################################################

for iter in {1..10}; do
  echo "-----------------------------------------------------------"
  echo "Iteration $iter / 5: Running main branch benchmark..."
  echo "-----------------------------------------------------------"
  gcloud compute ssh vm-benchmark \
    --zone="$ZONE" \
    --quiet \
    --ssh-flag="-o StrictHostKeyChecking=no" \
    --ssh-flag="-o UserKnownHostsFile=/dev/null" \
    --command "
      set -e
      cd ~/exchange-main
      sudo SKIP_BUILD=true BENCHMARK_LOG=log/benchmark-main-combined.log ./scripts/run-benchmark 100000
    "

  echo "-----------------------------------------------------------"
  echo "Iteration $iter / 5: Running new branch benchmark ($NEW_BRANCH)..."
  echo "-----------------------------------------------------------"
  gcloud compute ssh vm-benchmark \
    --zone="$ZONE" \
    --quiet \
    --ssh-flag="-o StrictHostKeyChecking=no" \
    --ssh-flag="-o UserKnownHostsFile=/dev/null" \
    --command "
      set -e
      cd ~/exchange-new
      sudo SKIP_BUILD=true BENCHMARK_LOG=log/benchmark-new-combined.log ./scripts/run-benchmark 100000
    "
done

###########################################################
echo "Copying logs back to managing plane VM..."
###########################################################

MAIN_LOG_REL="log/benchmark-main-combined.log"
NEW_LOG_REL="log/benchmark-new-combined.log"

echo "Using main log path: $MAIN_LOG_REL"
echo "Using new log path: $NEW_LOG_REL"

NEW_BRANCH_CLEAN="${NEW_BRANCH//\//_}"
COMMIT=$(git rev-parse --short=7 HEAD)
DEST_DIR="$PROJECT_ROOT/log/${NEW_BRANCH_CLEAN}-${COMMIT}"

echo "Creating directory: $DEST_DIR"
mkdir -p "$DEST_DIR"
chown "$USER:$USER" "$DEST_DIR" 2>/dev/null || true
chmod 755 "$DEST_DIR" 2>/dev/null || true

# Copy logs
if [[ -n "$MAIN_LOG_REL" ]]; then
  gcloud compute scp \
    --zone="$ZONE" \
    --scp-flag="-o StrictHostKeyChecking=no" \
    --scp-flag="-o UserKnownHostsFile=/dev/null" \
    vm-benchmark:"~/exchange-main/$MAIN_LOG_REL" \
    "$DEST_DIR/" || echo "Warning: Failed to copy main log"
fi

if [[ -n "$NEW_LOG_REL" ]]; then
  gcloud compute scp \
    --zone="$ZONE" \
    --scp-flag="-o StrictHostKeyChecking=no" \
    --scp-flag="-o UserKnownHostsFile=/dev/null" \
    vm-benchmark:"~/exchange-new/$NEW_LOG_REL" \
    "$DEST_DIR/" || echo "Warning: Failed to copy new log"
fi

###########################################################
echo "Configuring Python environment and running latency comparison..."
###########################################################

# Ensure Python requirements are met
"$PROJECT_ROOT/scripts/setup-python-env"

# Activate virtual environment if it exists
if [ -d "$PROJECT_ROOT/.venv" ]; then
  source "$PROJECT_ROOT/.venv/bin/activate"
fi

MAIN_LOG_FILE="$DEST_DIR/$(basename "$MAIN_LOG_REL")"
NEW_LOG_FILE="$DEST_DIR/$(basename "$NEW_LOG_REL")"

if [[ -f "$MAIN_LOG_FILE" && -f "$NEW_LOG_FILE" ]]; then
  echo "Running latency comparison..."
  TIME=$(date +%H%M%S)
  REPORT_FILE="$DEST_DIR/report-${NEW_BRANCH_CLEAN}-${COMMIT}-${TIME}.log"
  HEATMAP_FILE="$DEST_DIR/heatmap.png"
  
  python3 "$PROJECT_ROOT/scripts/compare_latency.py" \
    --baseline "$MAIN_LOG_FILE" \
    --candidate "$NEW_LOG_FILE" \
    --report-out "$REPORT_FILE" \
    --heatmap-out "$HEATMAP_FILE"
else
  echo "Error: Benchmark logs were not found!" >&2
  exit 1
fi

echo "Benchmark workflow completed successfully!"