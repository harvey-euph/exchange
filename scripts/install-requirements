#!/usr/bin/env bash
# Script to install all system dependencies for the Exchange project.
set -euo pipefail

echo "Updating package lists..."
sudo apt-get update

echo "Installing required packages..."
sudo apt-get install -y \
  build-essential \
  git \
  clang \
  software-properties-common \
  pkg-config \
  libssl-dev \
  zlib1g-dev \
  libboost-all-dev \
  libpq-dev \
  libpqxx-dev \
  flatbuffers-compiler \
  libflatbuffers-dev \
  libgtest-dev \
  googletest \
  libgmock-dev \
  libbpf-dev \
  bpftool \
  systemtap-sdt-dev \
  libspdlog-dev \
  libfmt-dev \
  nodejs \
  npm \
  gdb

echo "System dependencies installed successfully."
