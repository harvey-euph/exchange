#!/usr/bin/env bash
# Script to install all system dependencies for the Exchange project.
set -euo pipefail

echo "Updating package lists..."
sudo apt-get update

# ── Core build tools ──────────────────────────────────────────────────────────
echo "Installing core dependencies..."
sudo apt-get install -y \
  build-essential \
  git \
  clang \
  curl \
  lsb-release \
  pkg-config \
  libssl-dev \
  zlib1g-dev \
  libboost-all-dev \
  libpq-dev \
  libpqxx-dev \
  flatbuffers-compiler \
  libflatbuffers-dev \
  libgtest-dev \
  googletest \
  libgmock-dev \
  libbpf-dev \
  bpftool \
  systemtap-sdt-dev \
  tmux

# ── Node.js ───────────────────────────────────────────────────────────────────
# NodeSource LTS bundles npm – do NOT install apt's npm package separately.
echo "Installing Node.js (via NodeSource LTS)..."
if ! command -v node &>/dev/null; then
  curl -fsSL https://deb.nodesource.com/setup_lts.x | sudo -E bash -
  sudo apt-get install -y nodejs
fi
echo "  node $(node --version), npm $(npm --version)"

# ── Apache Arrow + Parquet ────────────────────────────────────────────────────
# Required for ebpf-msg-flow --parquet and compare_latency.py (pyarrow).
# Ubuntu universe's libarrow-dev has unresolvable transitive deps on most
# releases; use the official Apache Arrow APT repository instead.
echo "Installing Apache Arrow / Parquet C++ libraries..."
if ! pkg-config --exists arrow parquet 2>/dev/null; then
  CODENAME=$(lsb_release -cs)
  DISTRO=$(lsb_release -is | tr 'A-Z' 'a-z')
  DEB_URL="https://apache.jfrog.io/artifactory/arrow/${DISTRO}/apache-arrow-apt-source-latest-${CODENAME}.deb"
  echo "  Adding Apache Arrow APT source for ${DISTRO}/${CODENAME}..."
  curl -fsSL "$DEB_URL" -o /tmp/apache-arrow-apt-source.deb
  sudo apt-get install -y /tmp/apache-arrow-apt-source.deb
  rm -f /tmp/apache-arrow-apt-source.deb
  sudo apt-get update
fi
sudo apt-get install -y libarrow-dev libparquet-dev
echo "  Arrow $(pkg-config --modversion arrow), Parquet $(pkg-config --modversion parquet)"

echo "System dependencies installed successfully."
